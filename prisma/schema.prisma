generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
}

enum RepairRequestStatus {
  WAITING_FOR_REVIEW
  WAITING_FOR_RESPONSE
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
}

enum RepairStatus {
  ON_THE_WAY_TO_SHOP
  RECEIVED
  IN_DIAGNOSIS
  WAITING_FOR_PARTS
  IN_REPAIR
  IN_QA
  IN_OUTGOING
  ON_THE_WAY_TO_CUSTOMER
  DELIVERED
  ARCHIVED
}

enum PartOrderStatus {
  DRAFT
  ORDERED
  SHIPPED
  RECEIVED
  INSTALLED
  CANCELLED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String?  @unique
  passwordHash String
  displayName  String?
  avatarUrl    String?
  role         UserRole @default(CUSTOMER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customerRequests          RepairRequest[]             @relation("CustomerRequests")
  assignedRequests          RepairRequest[]             @relation("AssignedRequests")
  messages                  RepairMessage[]
  notes                     RepairNote[]
  workItems                 RepairWorkItem[]
  partOrders                PartOrder[]
  notifications             Notification[]
  uploadedFiles             RepairAttachment[]
  statusHistoryCreated      RepairStatusHistory[]
  createdWorkItemTypes      WorkItemType[]
  createdMessageChannels    MessageChannel[]
  messageChannelMemberships MessageChannelParticipant[]

  @@index([role, isActive])
}

model DeviceCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  devices DeviceCategories[]
}

model Device {
  id               String   @id @default(cuid())
  name             String   @unique
  description      String?
  purchaseValue    Decimal? @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deviceBrandId    String

  deviceCategories DeviceCategories[]
  repairDevices    RepairDevice[]
  deviceBrand      DeviceBrand        @relation(fields: [deviceBrandId], references: [id], onDelete: Cascade)
}

model DeviceBrand {
  id   String @id @default(cuid())
  name String @unique

  devices       Device[]
}

model DeviceCategories {
  id         String @id @default(cuid())
  deviceId   String
  categoryId String

  device   Device         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  category DeviceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model RepairRequest {
  id                    String              @id @default(cuid())
  customerId            String
  assignedStaffId       String?
  status                RepairRequestStatus @default(WAITING_FOR_REVIEW)
  priority              Int                 @default(0)
  queuePosition         Int?
  estimatedCompletionAt DateTime?
  subject               String
  deviceName            String
  deviceBrand           String?
  deviceModel           String?
  serialNumber          String?
  trackingNumber        String?
  problemDescription    String
  alreadyTried          String?
  suspectedIssue        String?
  customerNotes         String?
  internalSummary       String?
  rejectedReason        String?
  acceptedAt            DateTime?
  closedAt              DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  customer       User                  @relation("CustomerRequests", fields: [customerId], references: [id], onDelete: Cascade)
  assignedStaff  User?                 @relation("AssignedRequests", fields: [assignedStaffId], references: [id], onDelete: SetNull)
  device         RepairDevice?
  notes          RepairNote[]
  statusHistory  RepairStatusHistory[]
  workItems      RepairWorkItem[]
  partOrders     PartOrder[]
  attachments    RepairAttachment[]
  notifications  Notification[]
  messageChannel MessageChannel?

  @@index([customerId, status])
  @@index([assignedStaffId, status])
  @@index([status, createdAt])
}

model RepairDevice {
  id            String   @id @default(cuid())
  requestId     String   @unique
  deviceId      String?
  displayName   String
  serialNumber  String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  request       RepairRequest?        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  device        Device?               @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  statusHistory RepairStatusHistory[]
  workItems     RepairWorkItem[]
  partOrders    PartOrder[]
}

model RepairStatusHistory {
  id              String       @id @default(cuid())
  requestId       String
  deviceId        String?
  status          RepairStatus
  customText      String?
  note            String?
  startedAt       DateTime     @default(now())
  endedAt         DateTime?
  durationMinutes Int?
  createdById     String?
  createdAt       DateTime     @default(now())

  request   RepairRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  device    RepairDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  createdBy User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([requestId, startedAt])
  @@index([deviceId, startedAt])
}

model MessageChannel {
  id          String   @id @default(cuid())
  requestId   String   @unique
  createdById String?
  title       String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  request      RepairRequest               @relation(fields: [requestId], references: [id], onDelete: Cascade)
  createdBy    User?                       @relation(fields: [createdById], references: [id], onDelete: SetNull)
  messages     RepairMessage[]
  participants MessageChannelParticipant[]

  @@index([createdById, createdAt])
}

model WorkItemType {
  id          String   @id @default(cuid())
  createdById String?
  name        String   @unique
  slug        String   @unique
  description String?
  color       String?
  icon        String?
  sortOrder   Int      @default(0)
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)
  workItems RepairWorkItem[]

  @@index([createdById, isActive])
  @@index([isActive, sortOrder])
}

model RepairMessage {
  id         String    @id @default(cuid())
  channelId  String
  senderId   String?
  content    String
  isInternal Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  channel MessageChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender  User?          @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([channelId, createdAt])
  @@index([senderId, createdAt])
}

model MessageChannelParticipant {
  id         String    @id @default(cuid())
  channelId  String
  userId     String
  lastReadAt DateTime?
  isMuted    Boolean   @default(false)
  canReply   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  channel MessageChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId, lastReadAt])
}

model RepairNote {
  id        String   @id @default(cuid())
  requestId String
  authorId  String?
  title     String?
  content   String
  isPrivate Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  request RepairRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  author  User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([requestId, createdAt])
}

model RepairWorkItem {
  id             String   @id @default(cuid())
  requestId      String
  deviceId       String?
  createdById    String?
  workItemTypeId String
  title          String
  description    String?
  orderIndex     Int      @default(0)
  laborMinutes   Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  request      RepairRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  device       RepairDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  createdBy    User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  workItemType WorkItemType  @relation(fields: [workItemTypeId], references: [id], onDelete: Restrict)

  @@index([requestId, orderIndex])
  @@index([deviceId, workItemTypeId])
}

model PartCatalog {
  id           String   @id @default(cuid())
  name         String
  manufacturer String?
  sku          String?
  description  String?
  unitCost     Decimal? @db.Decimal(12, 2)
  retailPrice  Decimal? @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  partOrders PartOrder[]

  @@index([name, manufacturer])
  @@index([sku])
}

model PartOrder {
  id            String          @id @default(cuid())
  requestId     String
  deviceId      String?
  catalogPartId String?
  createdById   String?
  status        PartOrderStatus @default(DRAFT)
  quantity      Int             @default(1)
  orderedName   String
  supplierName  String?
  estimatedCost Decimal?        @db.Decimal(12, 2)
  actualCost    Decimal?        @db.Decimal(12, 2)
  savedValue    Decimal?        @db.Decimal(12, 2)
  orderedAt     DateTime?
  receivedAt    DateTime?
  installedAt   DateTime?
  note          String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  request     RepairRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  device      RepairDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  catalogPart PartCatalog?  @relation(fields: [catalogPartId], references: [id], onDelete: SetNull)
  createdBy   User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([requestId, status])
  @@index([deviceId, status])
}

model RepairAttachment {
  id           String   @id @default(cuid())
  requestId    String
  uploadedById String?
  fileName     String
  fileUrl      String
  mimeType     String?
  sizeBytes    Int?
  createdAt    DateTime @default(now())

  request    RepairRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  uploadedBy User?         @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([requestId, createdAt])
}

model Notification {
  id           String             @id @default(cuid())
  userId       String
  requestId    String?
  status       NotificationStatus @default(PENDING)
  subject      String
  body         String
  sentAt       DateTime?
  failedAt     DateTime?
  errorMessage String?
  createdAt    DateTime           @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  request RepairRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([requestId, createdAt])
}
