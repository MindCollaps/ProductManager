# Database Configuration
# Replace POSTGRES_USER and POSTGRES_PASSWORD with your actual credentials
DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@db:5432/productmanagerdb

# PostgreSQL Configuration
# IMPORTANT: Use strong, unique passwords in production
POSTGRES_USER=xxx
POSTGRES_PASSWORD=xxx
POSTGRES_DB=productmanagerdb

# Redis Configuration
REDIS_HOST=redis
# IMPORTANT: Use a strong password for Redis in production
REDIS_PASSWORD=xxx

# CORS Configuration (optional)
# Comma-separated list of allowed origins for Socket.io connections
# Example: ALLOWED_ORIGINS=https://example.com,https://app.example.com
# Leave empty or use '*' to allow all origins (not recommended for production)
ALLOWED_ORIGINS=

# DEV User
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com\
ADMIN_PASSWORD=admin

# App URL used in email links
APP_BASE_URL=http://localhost:8080

# Mail transport (SMTP)
MAIL_FROM=Product Manager <no-reply@example.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Mail debugging/testing
MAIL_PRINT_TO_CONSOLE=false
MAIL_PRINT_ONLY=false

# Notification digest scheduler
NOTIFICATION_DIGEST_ENABLED=true
NOTIFICATION_DIGEST_INTERVAL_MINUTES=30
NOTIFICATION_DIGEST_LOCK_TTL_MS=300000